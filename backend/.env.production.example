# Variables de Entorno para Producción

## Backend (.env en Render)

NODE_ENV=production
PORT=10000

# Base de datos (Railway/PlanetScale)
DB_HOST=tu_mysql_host_aqui
DB_PORT=3306
DB_NAME=railway
DB_USER=root
DB_PASSWORD=tu_password_aqui

# JWT Secrets (generar claves aleatorias de 64 caracteres)
JWT_SECRET=genera_una_clave_larga_aleatoria_de_64_caracteres_minimo
JWT_REFRESH_SECRET=genera_otra_clave_diferente_de_64_caracteres_minimo
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# URLs (actualizar después del deploy)
FRONTEND_URL=https://tu-frontend.vercel.app
BACKEND_URL=https://crm-lite-backend.onrender.com

# Company Info
COMPANY_NAME=CRM Lite ERP
COMPANY_EMAIL=info@crmlite.com
COMPANY_PHONE=+1 (809) 555-1234
COMPANY_ADDRESS=Santo Domingo, República Dominicana

# Stripe (opcional)
STRIPE_SECRET_KEY=sk_test_tu_clave
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook

# Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_password_app
