# Configuración del Backend
PORT=5000

# Base de Datos MySQL
DB_NAME=crm_lite
DB_USER=root
DB_PASSWORD=tu_password_mysql_seguro
DB_HOST=localhost
DB_PORT=3306

# JWT Secret (GENERA UNO SEGURO PARA PRODUCCIÓN)
# Usa: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_jwt_secret_muy_seguro_para_produccion_de_al_menos_512_caracteres_generado_aleatoriamente

# Configuración de Email (opcional - requerido para notificaciones automáticas)
# Para Gmail: usar app password, no tu contraseña normal
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_app_password_de_gmail

# Configuración CORS (para desarrollo - restringir en producción)
CORS_ORIGIN=http://localhost:5173

# Configuración de Pagos (opcional - para integración con gateways reales)
# Stripe
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta_de_stripe
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_de_stripe

# PayPal
PAYPAL_CLIENT_ID=tu_client_id_de_paypal
PAYPAL_CLIENT_SECRET=tu_client_secret_de_paypal
PAYPAL_MODE=sandbox  # sandbox o live

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=tu_access_token_de_mercadopago

# Gateway por defecto
DEFAULT_PAYMENT_GATEWAY=stripe

# Configuración de Seguridad
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=1d
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=15m