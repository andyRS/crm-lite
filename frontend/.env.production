# Variables de Entorno para Producción Frontend

# Backend API URL (actualizar con tu URL de Render)
VITE_API_URL=https://crm-lite-backend.onrender.com/api

# Socket.IO URL (mismo dominio del backend)
VITE_SOCKET_URL=https://crm-lite-backend.onrender.com

# Entorno
VITE_ENV=production

# Stripe (opcional)
VITE_STRIPE_PUBLIC_KEY=pk_test_tu_clave_publica
